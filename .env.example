# Runtime e segredos
JOB_HUNTER_TELEGRAM_TOKEN=coloque-seu-token-aqui
JOB_HUNTER_TELEGRAM_CHAT_ID=coloque-seu-chat-id-aqui
JOB_HUNTER_APPLICATION_CONTACT_EMAIL=
JOB_HUNTER_APPLICATION_PHONE=
JOB_HUNTER_APPLICATION_PHONE_COUNTRY_CODE=
JOB_HUNTER_CANDIDATE_PROFILE_PATH=./candidate_profile.json
JOB_HUNTER_SKILL_TAXONOMY_PATH=./skill_taxonomy.json
JOB_HUNTER_LINKEDIN_COMPANY_POLICY_PATH=./linkedin_company_policy.json
JOB_HUNTER_OPERATIONAL_POLICY_PATH=./operational_policy.json
JOB_HUNTER_COLLECTION_TIME=08:00
JOB_HUNTER_DATABASE_PATH=./jobs.db
JOB_HUNTER_BROWSER_USE_CONFIG_DIR=./.browseruse
JOB_HUNTER_LINKEDIN_PERSISTENT_PROFILE_DIR=./.browseruse/profiles/linkedin-bootstrap
JOB_HUNTER_LINKEDIN_STORAGE_STATE_PATH=./.browseruse/linkedin-storage-state.json
JOB_HUNTER_BROWSER_HEADLESS=false
JOB_HUNTER_LINKEDIN_MAX_PAGES_PER_CYCLE=2
JOB_HUNTER_LINKEDIN_MAX_PAGE_DEPTH=6
JOB_HUNTER_LINKEDIN_SCROLL_STABILIZATION_PASSES=3
JOB_HUNTER_LINKEDIN_DUPLICATE_PAGES_STOP_THRESHOLD=2
JOB_HUNTER_SAVE_FAILURE_ARTIFACTS=false
JOB_HUNTER_FAILURE_ARTIFACTS_DIR=./.artifacts/linkedin_failures
JOB_HUNTER_REVIEW_POLLING_GRACE_SECONDS=120
JOB_HUNTER_ADAPTIVE_POLLING_BACKOFF_ENABLED=true
JOB_HUNTER_ADAPTIVE_POLLING_EMPTY_CYCLES_BEFORE_BACKOFF=2
JOB_HUNTER_ADAPTIVE_POLLING_BACKOFF_MULTIPLIER=2.0
JOB_HUNTER_ADAPTIVE_POLLING_MAX_INTERVAL_SECONDS=900
JOB_HUNTER_LINKEDIN_FIELD_REPAIR_ENABLED=true
JOB_HUNTER_APPLICATION_SUPPORT_LLM_ENABLED=true
JOB_HUNTER_JOB_REQUIREMENTS_LLM_ENABLED=true
JOB_HUNTER_REVIEW_RATIONALE_LLM_ENABLED=true
JOB_HUNTER_APPLICATION_PRIORITY_LLM_ENABLED=true
JOB_HUNTER_PRIORITY_HIGH_MIN_RELEVANCE=8
JOB_HUNTER_PRIORITY_MEDIUM_MIN_RELEVANCE=6
JOB_HUNTER_PRIORITY_PREFERRED_WORK_MODES=remoto,hibrido,hybrid,remote
JOB_HUNTER_OLLAMA_MODEL=qwen2.5:7b
JOB_HUNTER_OLLAMA_URL=http://localhost:11434

# Matching estruturado principal
# O runtime agora prefere este arquivo como fonte principal de matching.
JOB_HUNTER_STRUCTURED_MATCHING_CONFIG_PATH=./job_target.json
JOB_HUNTER_STRUCTURED_MATCHING_FALLBACK_ENABLED=false

# Compatibilidade legada
# Mantenha estes campos apenas enquanto o fallback legado ainda for necessário.
# Não expanda o uso de PROFILE_TEXT em código novo.
JOB_HUNTER_PROFILE_TEXT=
JOB_HUNTER_INCLUDE_KEYWORDS=
JOB_HUNTER_EXCLUDE_KEYWORDS=
JOB_HUNTER_ACCEPTED_WORK_MODES=
JOB_HUNTER_MINIMUM_SALARY_BRL=0
JOB_HUNTER_MINIMUM_RELEVANCE=6

# Toggles operacionais de teste
JOB_HUNTER_RELAXED_MATCHING_FOR_TESTING=false
JOB_HUNTER_RELAXED_TESTING_PROFILE_HINT=Para testes controlados de parsing, considere tambem vagas junior e pleno como aceitaveis.
JOB_HUNTER_RELAXED_TESTING_REMOVE_EXCLUDE_KEYWORDS=junior
JOB_HUNTER_RELAXED_TESTING_MINIMUM_RELEVANCE=4
